{
  "name": "code-quest",
  "displayName": "Code Quest",
  "description": "A pixel-art RPG that visualizes your coding activity \u2014 defeat monsters by writing code",
  "version": "0.1.0",
  "publisher": "Leon2110",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "copilot-px",
          "title": "Code Quest",
          "icon": "icon128.png"
        }
      ]
    },
    "views": {
      "copilot-px": [
        {
          "type": "webview",
          "id": "copilotPx.panel",
          "name": " "
        }
      ]
    },
    "commands": [
      {
        "command": "copilotPx.open",
        "title": "Code Quest: Open Panel"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  },
  "icon": "icon128.png",
  "keywords": [
    "game",
    "pixel",
    "productivity",
    "stats",
    "fun"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Leon2110/Copilot_Visualization"
  }
}